# =============================================================================
# BEL Backend — Environment Variables
# Copy this file to .env and fill in the values. NEVER commit .env to git.
# =============================================================================

# --- AI Providers --------------------------------------------------------
# OpenRouter keys (tried in order on rate-limit / auth errors).
# Provide at least one. Get keys at https://openrouter.ai/
OPENROUTER_API_KEY_1=
OPENROUTER_API_KEY_2=
OPENROUTER_API_KEY_3=
OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# Groq (fallback). Get a key at https://console.groq.com/
GROQ_API_KEY=

# Fallback order. Comma-separated; first one tried first.
AI_FALLBACK_ORDER=openrouter,groq

# --- Server --------------------------------------------------------------
PORT=8000
LOG_LEVEL=INFO

# Comma-separated allowed origins. RESTRICT in production.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- File uploads --------------------------------------------------------
UPLOAD_DIR=uploads
# Upload cap in MB. Bump higher for very large enterprise datasets.
MAX_UPLOAD_SIZE_MB=500
